# shellcheck shell=bash
# shellcheck source=/dev/null

path_prepend () {
  case ":$PATH:" in
    *":$1:"*) ;;
    *) PATH="$1:$PATH" ;;
  esac
}

# load aliases
[ -r ~/.bash_aliases ] && . ~/.bash_aliases

# load work setup
[ -r ~/.bashrc.work ] && . ~/.bashrc.work

# Don't put duplicate lines in the history and do not add lines that start with a space
export HISTCONTROL=erasedups:ignoredups:ignorespace

# append to the history file, don't overwrite it
shopt -s histappend

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=100000
HISTFILESIZE=100000

# Save and reload the history after each command finishes
# export PROMPT_COMMAND="history -a; history -c; history -r; $PROMPT_COMMAND"

# check the window size after each command and, if necessary,
# update the values of LINES and COLUMNS.
shopt -s checkwinsize

if echo "$-" | grep -q i; then
  # Disable the bell
  bind "set bell-style visible"

  # Ignore case on auto-completion
  # Note: bind used instead of sticking these in .inputrc
  bind "set completion-ignore-case on"

  # Show auto-completion list automatically, without double tab
  bind "set show-all-if-ambiguous On"
fi

# Set the default editor
if command -v hx >/dev/null 2>&1; then
  export EDITOR=hx
  export VISUAL=hx
fi
# Set the default editor end

# Local tools
path_prepend "$HOME/tools"

# HomeBrew
if command -v brew >/dev/null 2>&1; then
  BREW_PREFIX="$(brew --prefix)"
  eval "$("${BREW_PREFIX}"/bin/brew shellenv)"
  path_prepend "${BREW_PREFIX}/bin"
  path_prepend "${BREW_PREFIX}/sbin"
  path_prepend "${BREW_PREFIX}/opt/grep/libexec/gnubin"
fi
# HomeBrew end

# coreutils
if command -v brew >/dev/null 2>&1; then
  path_prepend "$(brew --prefix coreutils)/libexec/gnubin"
fi
# coreutils end

# starship
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init bash)"
fi
# starship end

# dotnet
path_prepend "$HOME/.dotnet/tools"

if [ -x "/opt/homebrew/opt/dotnet/libexec/dotnet" ]; then
  path_prepend "/opt/homebrew/opt/dotnet/libexec"
  export DOTNET_ROOT="/opt/homebrew/opt/dotnet/libexec"
elif [ -x "/usr/local/share/dotnet/dotnet" ]; then
  path_prepend "/usr/local/share/dotnet"
  export DOTNET_ROOT="/usr/local/share/dotnet"
elif [ -x "$HOME/.dotnet/dotnet" ]; then
  path_prepend "$HOME/.dotnet"
  export DOTNET_ROOT="$HOME/.dotnet"
fi
# dotnet end

# gawk
if command -v brew >/dev/null 2>&1 && ! command -v gawk >/dev/null 2>&1; then
  path_prepend "$(brew --prefix gawk)/libexec/gnubin"
fi
# gawk end

# GitHub CLI completion
if command -v gh >/dev/null 2>&1; then
  eval "$(gh completion -s bash)"
fi
# GitHub CLI completion end

# fzf
if command -v fzf >/dev/null 2>&1; then
  eval "$(fzf --bash)"
fi
# fzf end

# carapace
if command -v carapace >/dev/null 2>&1; then
  export CARAPACE_BRIDGES='bash'
  eval "$(carapace _carapace)"
fi
# carapace end

# Bash completion
[ -n "${BREW_PREFIX:-}" ] && [ -r "${BREW_PREFIX}/etc/profile.d/bash_completion.sh" ] && . "${BREW_PREFIX}/etc/profile.d/bash_completion.sh"
# Bash completion end

# glow
if command -v glow >/dev/null 2>&1; then
  eval "$(glow completion bash)"
fi
# glow end

# GPG TTY for git signing
if command -v tty >/dev/null 2>&1; then
  GPG_TTY="$(tty)"
  export GPG_TTY
fi
# GPG TTY for git signing end

# codex
if command -v codex >/dev/null 2>&1; then
  eval "$(codex completion bash)"
fi
# codex end
